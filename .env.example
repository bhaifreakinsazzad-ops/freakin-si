# ── Freakin SI — Environment Variables ──────────────────
# Copy this file to apps/backend/.env and fill in your values

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# AI Providers (Free)
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...
COHERE_API_KEY=...

# AI Providers (Pro tier — optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Payment (bKash/Nagad)
PAYMENT_PHONE=01XXXXXXXXX

# Admin
ADMIN_EMAIL=admin@freakin-si.com
ADMIN_EMAILS=admin@freakin-si.com,owner@freakin-si.com

# Subscription
FREE_TRIAL_DAYS=7
